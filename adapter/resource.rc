#include <winver.h>

// Explorer/file icon — the shared DisplayXR app tile (white mark on dark
// rounded rect, legible on both light and dark Explorer themes). Same asset
// as displayxr-runtime/assets/displayxr_app.ico.
1 ICON "../assets/displayxr_app.ico"

VS_VERSION_INFO VERSIONINFO
FILEVERSION     1,0,0,0
PRODUCTVERSION  1,0,0,0
FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
FILEFLAGS       0
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "The DisplayXR Project"
            VALUE "FileDescription",  "DisplayXR MCP Adapter"
            VALUE "FileVersion",      "1.0.0.0"
            VALUE "InternalName",     "displayxr-mcp"
            VALUE "LegalCopyright",   "Copyright 2026 The DisplayXR Project and its contributors"
            VALUE "OriginalFilename", "displayxr-mcp.exe"
            VALUE "ProductName",      "DisplayXR MCP"
            VALUE "ProductVersion",   "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
